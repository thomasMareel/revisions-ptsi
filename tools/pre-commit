#!/bin/sh
# Hook pre-commit — valide index.html avant chaque commit.
# Installation : copier ce fichier dans .git/hooks/pre-commit (voir tools/install-hooks.sh).

if command -v python >/dev/null 2>&1; then
  PY=python
elif command -v py >/dev/null 2>&1; then
  PY=py
else
  echo "[pre-commit] Python introuvable — validation ignorée."
  exit 0
fi

"$PY" tools/validate.py
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "[pre-commit] Validation échouée — commit annulé."
  echo "Corrige les erreurs ci-dessus, ou force avec: git commit --no-verify"
fi
exit $status
